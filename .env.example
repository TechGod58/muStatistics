# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mu_statistics

# Portable mode runs with an embedded local database and can serve the built web app from the API.
MU_PORTABLE=0
MU_PORTABLE_DB_DIR=./data/portable-db
MU_SERVE_WEB=0
MU_SQL_HOOK_ENABLED=0
MU_SQL_EXTERNAL_URL=
MU_OFFICE_HOOK_ENABLED=0
MU_OFFICE_WORD_PATH=
MU_OFFICE_EXCEL_PATH=

# Axion Parallel Cubed + QECC sidecar integration
MU_AXION_SIDECAR_ENABLED=0
MU_AXION_SIDECAR_AUTOSTART=1
MU_AXION_SIDECAR_URL=http://127.0.0.1:8765
MU_AXION_SIDECAR_SCRIPT_PATH=./services/axion/axion_sidecar.py
MU_AXION_PARALLEL_CUBED_GENOME=./services/axion/parallel_cubed_region_genome.json
MU_AXION_PYTHON_COMMAND=py
MU_AXION_PYTHON_ARGS=-3.11
MU_AXION_PREFILTER_ENABLED=1
MU_AXION_PREFILTER_MIN_SCORE=0.08
MU_AXION_QECC_GUARD_ENABLED=1

# SPSS bridge for .sav/.zsav import/export
MU_SPSS_BRIDGE_SCRIPT_PATH=./services/spss/spss_bridge.py
MU_SPSS_PYTHON_COMMAND=py
MU_SPSS_PYTHON_ARGS=-3.11

# SEM / AMOS parity strategy and integration boundary
MU_SEM_PARITY_STRATEGY=integration_boundary
MU_SEM_PROVIDER=amos
MU_SEM_HOOK_ENABLED=0
MU_AMOS_EXECUTABLE_PATH=
MU_SEM_BRIDGE_SCRIPT_PATH=./services/spss/sem_bridge.py

# Session secret - change this to any long random string in production
SESSION_SECRET=mu-statistics-change-this-secret-key-32chars

# Frontend origin allowed to call the API with credentials
APP_ORIGIN=http://localhost:3000
MU_STORAGE_ROOT=./data
OIDC_PROVIDER_NAME=MU Single Sign-On
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4000/auth/oidc/callback
OIDC_SCOPES=openid profile email
OIDC_ALLOWED_EMAIL_DOMAIN=
OIDC_EXPECTED_AUDIENCE=
OIDC_ALLOW_USERINFO_FALLBACK=0

# API port (optional, defaults to 4000)
PORT=4000

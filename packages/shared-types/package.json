{
    "name":  "@mu/shared-types",
    "version":  "0.1.0",
    "type":  "module",
    "main":  "dist/index.js",
    "types":  "dist/index.d.ts",
  "exports":  {
                    ".":  {
                              "types":  "./src/index.ts",
                              "import":  "./src/index.mjs",
                              "default":  "./src/index.mjs"
                          }
                },
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "test":  "vitest run --passWithNoTests",
                    "typecheck":  "tsc -p tsconfig.json --noEmit"
                },
    "devDependencies":  {
                            "typescript":  "^5.7.3",
                            "vitest":  "^2.1.8"
                        }
}
